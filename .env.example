# Clerk (https://clerk.com) — Optional for auth
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Stripe (https://dashboard.stripe.com/apikeys) — Optional for payments
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Database — Not required for local dev (uses in-memory store)
# For production, set DATABASE_URL to a Postgres connection string
# DATABASE_URL=postgresql://__REDACTED__use_process.env.DATABASE_URL
